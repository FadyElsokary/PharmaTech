{
  "name": "pharmatech",
  "version": "1.0.0",
  "description": "Pharmacy Management System - نظام إدارة الصيدليات",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win"
  },
  "keywords": [
    "pharmacy",
    "inventory",
    "electron",
    "desktop",
    "pharmatech"
  ],
  "author": "PharmaTech Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "clsx": "^2.0.0",
    "electron": "^28.1.0",
    "i18next": "^23.7.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.0",
    "react-router-dom": "^6.21.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pharmatech.app",
    "productName": "PharmaTech",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon.ico"
    }
  }
}
